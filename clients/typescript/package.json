{
  "name": "@carbonfiles/client",
  "version": "0.1.0",
  "description": "TypeScript client for the CarbonFiles API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/carbungo/carbon-files.git",
    "directory": "clients/typescript"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "~5.8.0",
    "vitest": "^3.0.0"
  }
}
